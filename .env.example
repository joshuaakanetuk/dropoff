# --- Application Core Settings ---
BETTER_AUTH_SECRET="YOUR_SECURE_SECRET"
BETTER_AUTH_URL=http://localhost:3000

# Database connection URL (e.g., postgresql://user:pass@host:port/dbname)
DATABASE_URL=postgresql://user:password@localhost:5432/mydatabase

# --- Email Service Settings ---
EMAIL_USER="your-email@domain.com"
EMAIL_PASS="your-email-password"


# --- Cloud Storage (AWS S3 / R2) Settings ---
# These variables are required for cloud storage operations.
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_REGION=auto
S3_BUCKET=your-s3-bucket-name
# Optional: Endpoint for custom services (like Minio or R2)
AWS_ENDPOINT=https://endpoint.example.com

# R2 specific endpoint if using Cloudflare R2
R2_DEV_URL=http://localhost:9999
