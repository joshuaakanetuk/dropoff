{
  "model": "opus",
  "permissions": {
    "read": {
      "deny": [
        "**/.env*",
        "**/*.pem",
        "**/*.key",
        "**/secrets/**",
        "**/credentials/**",
        "**/.aws/**",
        "**/.ssh/**",
        "**/docker-compose*.yml",
        "**/config/database.yml",
        "Read(**/.env*)",
        "Read(**/env.php*)",
        "Read(**/*.pem)",
        "Read(**/*.key)",
        "Read(**/secrets/**)",
        "Read(**/credentials/**)",
        "Read(**/.aws/**)",
        "Read(**/.ssh/**)",
        "Read(**/docker-compose*.yml)",
        "Read(**/config/database.yml)"
      ]
    }
  },
  "effortLevel": "high"
}